# SUPABASE_URL: URL do projeto Supabase (obtido no painel Supabase)
VITE_SUPABASE_URL="https://SEU-PROJETO.supabase.co"

# SUPABASE_ANON_KEY: Chave pública do Supabase (obtida no painel Supabase > Settings > API)
VITE_SUPABASE_ANON_KEY="sua-chave-anon-aqui"

# APP_URL: URL de produção do site (usada nos links de referral)
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seu-dominio.com
VITE_APP_URL="http://localhost:3000"
